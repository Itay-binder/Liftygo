# --- Google Sheets (קיים) ---
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SPREADSHEET_ID=...
# GOOGLE_SHEET_RANGE='הזמנות (לא לשנות שם - MAKE)'!A:AL
# GOOGLE_DATE_COLUMN=תאריך הזמנה

# --- Firebase (התחברות + Firestore למשתמשים) ---
# JSON של Service Account מ-Firebase Console → Project settings → Service accounts
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# אותו מפתח Web מתוך Firebase → Project settings → Your apps → SDK snippet
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# אימיילים שיקבלו אוטומטית admin + approved (מופרדים בפסיק)
ADMIN_EMAILS=you@gmail.com

# iframe באתר אחר (Elementor): true — עוגיית session עם SameSite=None; Partitioned (חובה לדפדפנים חוסמי צד שלישי)
# SESSION_COOKIE_CROSS_SITE=true

# כמה ימים נשארת מחובר לפני שצריך להתחבר מחדש (1–14, ברירת מחדל 5)
# SESSION_MAX_AGE_DAYS=7

# ב-Firestore: users — מזהה מסמך = אימייל מנורמל (לא uid). מסמכים ישנים לפי uid ימוזגו אוטומטית בהתחברות.
# invites — מזהה מסמך = אימייל (או שדה email). אופציונלי: utmSource / utmSOURCE / utm_source.
# רק מיילים כאלה (או ADMIN_EMAILS, או משתמש שכבר ב-users) יכולים להתחבר.

# פיתוח מקומי בלי Firebase: true — מבטל התחברות ומגן API
# בפרודקשן: אל תגדיר או false
# AUTH_DISABLED=true
